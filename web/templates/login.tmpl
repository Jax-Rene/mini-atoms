{{ define "login_content" }}
<section class="mx-auto max-w-md">
  <div class="card">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Auth</p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight text-slate-950">登录</h1>
    <p class="mt-2 text-sm text-slate-600">使用邮箱和密码登录 mini atoms。</p>

    {{ if .Error }}
    <div class="error-box">{{ .Error }}</div>
    {{ end }}

    <form method="post" action="/login" class="mt-4">
      <label for="email" class="label">邮箱</label>
      <input id="email" name="email" type="email" required autocomplete="email" value="{{ .FormEmail }}" class="input">

      <label for="password" class="label">密码</label>
      <input id="password" name="password" type="password" required minlength="8" autocomplete="current-password" class="input">

      <button type="submit" class="btn-primary mt-5 w-full">登录</button>
    </form>

    <div class="mt-4 rounded-2xl border border-emerald-200 bg-emerald-50 p-4">
      <p class="text-sm font-semibold text-emerald-700">体验模式（面试演示）</p>
      <p class="mt-1 text-sm text-slate-600">无需注册，点击按钮将自动登录预置账号。</p>
      <p class="mt-2 text-xs text-slate-700">
        账号：<code>{{ .DemoLoginEmail }}</code><br>
        密码：<code>{{ .DemoLoginPassword }}</code>
      </p>
      <form method="post" action="/login/demo" class="mt-3">
        <button type="submit" class="btn-secondary w-full">体验模式（自动登录）</button>
      </form>
    </div>

    <p class="mt-4 text-sm text-slate-600">
      还没有账号？
      <a href="/register" class="font-medium text-slate-900 underline decoration-slate-300 underline-offset-4 hover:decoration-slate-700">去注册</a>
    </p>
  </div>
</section>
{{ end }}
