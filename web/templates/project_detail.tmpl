{{ define "project_workbench_content" }}
<section
  id="project-workbench"
  class="project-hardline-workbench project-detail-workbench-stage mt-4 grid gap-6 xl:items-stretch xl:grid-cols-[520px_minmax(0,1fr)]"
  x-data="projectWorkbenchState($el)"
