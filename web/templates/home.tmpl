{{ define "home_content" }}
<section class="card">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">M0 + M1 Ready</p>
      <h1 class="mt-1 text-3xl font-semibold tracking-tight text-slate-950">mini-atoms</h1>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">
        当前已完成 Go/Gin/GORM 项目骨架与邮箱认证（7 天 Session）。后续模块会继续补齐项目管理、Spec 生成与渲染能力。
      </p>
    </div>
    <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-3 py-2 text-xs font-medium text-emerald-700">
      P0 Sprint In Progress
    </div>
  </div>
</section>

{{ if .CurrentUserEmail }}
<section class="card">
  <h2 class="text-sm font-semibold text-slate-900">登录状态</h2>
  <p class="mt-2 text-sm text-slate-600">当前已登录：<code class="rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-700">{{ .CurrentUserEmail }}</code></p>
  <div class="mt-4">
    <a href="/projects" class="btn-primary">进入 Projects（M2 占位）</a>
  </div>
</section>
{{ else }}
<section class="card">
  <h2 class="text-sm font-semibold text-slate-900">开始使用</h2>
  <p class="mt-2 text-sm text-slate-600">先注册本地账号（邮箱 + 密码），后续就可以创建项目并生成应用。</p>
  <div class="mt-4 flex flex-wrap gap-3">
    <a href="/register" class="btn-primary">注册账号</a>
    <a href="/login" class="btn-secondary">已有账号，去登录</a>
  </div>
</section>
{{ end }}

<section class="grid gap-4 lg:grid-cols-2">
  <div class="card">
    <h2 class="text-sm font-semibold text-slate-900">运行环境</h2>
    <dl class="mt-3 space-y-2 text-sm text-slate-600">
      <div class="flex items-center justify-between gap-3">
        <dt>APP_ENV</dt>
        <dd><code class="rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-700">{{ .AppEnv }}</code></dd>
      </div>
      <div class="flex items-center justify-between gap-3">
        <dt>APP_ADDR</dt>
        <dd><code class="rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-700">{{ .HTTPAddr }}</code></dd>
      </div>
      <div class="flex items-center justify-between gap-3">
        <dt>DATABASE_PATH</dt>
        <dd><code class="rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-700">{{ .DatabasePath }}</code></dd>
      </div>
    </dl>
  </div>

</section>
{{ end }}

